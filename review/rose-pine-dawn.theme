        "Documentation":   { "text-color": "#56949f", "background-color": null, "bold": false, "italic": true,  "underline": false },
        "Error":           { "text-color": "#b4637a", "background-color": null, "bold": true,  "italic": false, "underline": true  },
        "Extension":       { "text-color": "#286983", "background-color": null, "bold": false, "italic": false, "underline": false },
        "Float":           { "text-color": "#d7827e", "background-color": null, "bold": false, "italic": false, "underline": false },
        "Function":        { "text-color": "#286983", "background-color": null, "bold": false, "italic": false, "underline": false },
        "Import":          { "text-color": "#907aa9", "background-color": null, "bold": false, "italic": false, "underline": false },
