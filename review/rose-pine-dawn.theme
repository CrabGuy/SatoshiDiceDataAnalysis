        "Other":           { "text-color": "#575279", "background-color": null, "bold": false, "italic": false, "underline": false },
        "Preprocessor":    { "text-color": "#907aa9", "background-color": null, "bold": false, "italic": false, "underline": false },
        "SpecialChar":     { "text-color": "#d7827e", "background-color": null, "bold": false, "italic": false, "underline": false },
        "SpecialString":   { "text-color": "#56949f", "background-color": null, "bold": false, "italic": false, "underline": false },
