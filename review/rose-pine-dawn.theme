        "Char":            { "text-color": "#56949f", "background-color": null, "bold": false, "italic": false, "underline": false },
        "Comment":         { "text-color": "#9893a5", "background-color": null, "bold": false, "italic": true,  "underline": false },
        "CommentVar":      { "text-color": "#9893a5", "background-color": null, "bold": false, "italic": true,  "underline": false },
        "Constant":        { "text-color": "#d7827e", "background-color": null, "bold": false, "italic": false, "underline": false },
